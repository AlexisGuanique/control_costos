# ─── Requeridos ───────────────────────────────────────────────────────────────

# Clave de API de Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Clave secreta para firmar JWT (genera una con: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_strong_random_secret_key

# ─── Opcionales (Docker en servidor) ──────────────────────────────────────────

# Puertos en el host (misma máquina que otras apps: ej. NutriTrack en 3010 → FinTrack usa 3020 + 8020)
# FINTRACK_WEB_PORT=3020
# FINTRACK_API_PORT=8020

# URL pública del API (mismo host + FINTRACK_API_PORT). Obligatorio al hacer docker compose build del frontend.
# NEXT_PUBLIC_API_URL=http://34.29.59.97:8020

# URL de la base de datos (por defecto SQLite en ./data/database.db)
# DATABASE_URL=sqlite:///./data/database.db

# Para producción con PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fintrack
